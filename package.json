{
  "name": "reader",
  "version": "0.1.0",
  "description": "A narrating, sentence-highlighting reading app. Phase 1: the skeleton.",
  "private": true,
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test \"test/unit/**/*.test.js\"",
    "smoke": "node test/smoke/launch.smoke.js",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "jszip": "^3.10.1",
    "kokoro-js": "^1.2.1"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "playwright": "^1.61.1"
  },
  "build": {
    "appId": "com.reader.app",
    "productName": "Reader",
    "files": [
      "src/**/*",
      "assets/**/*",
      "!assets/models/**/*",
      "package.json",
      "!test/**/*",
      "!docs/**/*"
    ],
    "asarUnpack": [
      "**/node_modules/onnxruntime-node/**"
    ],
    "extraResources": [
      {
        "from": "assets/models",
        "to": "assets/models"
      }
    ],
    "win": {
      "target": "portable",
      "artifactName": "Reader-${version}-portable.exe"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": "arm64"
        }
      ],
      "category": "public.app-category.books"
    },
    "directories": {
      "output": "dist"
    }
  }
}
